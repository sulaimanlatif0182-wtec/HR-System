generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Employee {
  id            Int            @id @default(autoincrement())
  firstName     String
  lastName      String
  email         String         @unique
  phone         String?
  department    String
  designation   String
  joinDate      String
  status        String         @default("active")
  createdAt     DateTime       @default(now())

  // Manager Relationship
  managerId     Int?
  manager       Employee?      @relation("ManagerEmployees", fields: [managerId], references: [id])
  teamMembers   Employee[]     @relation("ManagerEmployees")

  user          User?
  leaveRequests LeaveRequest[]
  leaveBalance  LeaveBalance?
}

model User {
  id            Int      @id @default(autoincrement())
  email         String   @unique
  password      String
  role          String   @default("employee")
  employeeId    Int?     @unique
  employee      Employee? @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  profilePhoto  String?
  createdAt     DateTime @default(now())
}

model LeaveRequest {
  id           Int      @id @default(autoincrement())
  employeeId   Int
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeName String
  leaveType    String
  startDate    String
  endDate      String
  reason       String
  status       String   @default("pending")
  appliedDate  String
  createdAt    DateTime @default(now())
}

model LeaveBalance {
  id          Int      @id @default(autoincrement())
  employeeId  Int      @unique
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  annualTotal Int      @default(14)
  sickTotal   Int      @default(7)
  casualTotal Int      @default(5)
  updatedAt   DateTime @updatedAt
}

model Attendance {
  id         Int      @id @default(autoincrement())
  employeeId Int
  date       String
  checkIn    String?
  checkOut   String?
  status     String
  createdAt  DateTime @default(now())
}